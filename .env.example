# OpenRouter API Configuration
# Get your API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Next.js Environment
NODE_ENV=development

# Site Configuration — preferred host is www (apex redirects to www)
NEXT_PUBLIC_SITE_URL=https://www.madeiracanyonhomes.com

# Google Search Console — HTML tag verification
# 1. Open https://search.google.com/search-console
# 2. Add property: https://www.madeiracanyonhomes.com (URL-prefix) OR Domain property
# 3. Choose "HTML tag" verification → paste the content= value here (not the full meta tag)
# 4. Set the same var in Vercel Project → Settings → Environment Variables → Production
# 5. Redeploy, then click Verify in Search Console
# 6. Submit sitemap: https://www.madeiracanyonhomes.com/sitemap.xml
GOOGLE_SITE_VERIFICATION=
# Optional alias (same value):
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Dr. Jan Duffy headshot — Cloudflare Images (optional; falls back to /images/dr-jan-duffy.jpg)
# NEXT_PUBLIC_CLOUDFLARE_ACCOUNT_HASH=
# NEXT_PUBLIC_DR_JAN_CF_IMAGE_ID=
# NEXT_PUBLIC_DR_JAN_CF_VARIANT=public
# Or full override:
# NEXT_PUBLIC_DR_JAN_PHOTO_URL=https://imagedelivery.net/<hash>/<id>/public
