# OpenRouter API Configuration
# Get your API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Next.js Environment
NODE_ENV=development

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://heyberkshire.com

# Google Search Console — HTML tag verification (Settings > Ownership
# verification > HTML tag, copy only the `content` value). This verifies
# heyberkshire.com and any other domain that doesn't set its own
# `googleSiteVerification` in lib/domain-config.ts.
GOOGLE_SITE_VERIFICATION=
