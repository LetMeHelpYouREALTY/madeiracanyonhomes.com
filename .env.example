# OpenRouter API Configuration
# Get your API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Next.js Environment
NODE_ENV=development

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://madeiracanyonhomes.com

# Dr. Jan Duffy headshot — Cloudflare Images (optional; falls back to /images/dr-jan-duffy.jpg)
# NEXT_PUBLIC_CLOUDFLARE_ACCOUNT_HASH=
# NEXT_PUBLIC_DR_JAN_CF_IMAGE_ID=
# NEXT_PUBLIC_DR_JAN_CF_VARIANT=public
# Or full override:
# NEXT_PUBLIC_DR_JAN_PHOTO_URL=https://imagedelivery.net/<hash>/<id>/public
